{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "viz-server",
      "runtimeExecutable": "python",
      "runtimeArgs": ["-m", "http.server", "8765", "--directory", "data/viz"],
      "port": 8765
    },
    {
      "name": "pfd-web",
      "runtimeExecutable": "python3",
      "runtimeArgs": ["-m", "uvicorn", "web.app:app", "--reload", "--host", "0.0.0.0", "--port", "8000", "--app-dir", "src"],
      "port": 8000
    }
  ]
}
